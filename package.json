{
  "name": "@agent-capability-middleware/sdk",
  "version": "0.1.0-preview.11",
  "description": "TypeScript SDK for bounded, keyless agent consumption of x402 resources",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "keywords": [
    "ai-agents",
    "capabilities",
    "mcp",
    "permissions",
    "privacy",
    "x402"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InTheta/agent-capability-middleware.git"
  },
  "bugs": {
    "url": "https://github.com/InTheta/agent-capability-middleware/issues"
  },
  "homepage": "https://github.com/InTheta/agent-capability-middleware#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "acm": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:consumer": "tsc -p tsconfig.json && tsc --noEmit --strict --target ES2022 --module NodeNext --moduleResolution NodeNext examples/typecheck.ts",
    "test": "tsc -p tsconfig.json && node --test tests/*.test.mjs",
    "package:smoke": "tsc -p tsconfig.json && node scripts/smoke-package.mjs",
    "quickstart": "tsc -p tsconfig.json && node scripts/run-quickstart.mjs",
    "example:fresh-dev": "tsc -p tsconfig.json && node scripts/fresh-dev-setup.mjs",
    "example:bazaar": "tsc -p tsconfig.json && node examples/bazaar-discovery.mjs",
    "example:omni-x402": "tsc -p tsconfig.json && node examples/omni-x402.mjs",
    "example:omni-catalog": "tsc -p tsconfig.json && node examples/omni-catalog.mjs",
    "partner:check": "node scripts/design-partner-run.mjs",
    "cli:smoke": "tsc -p tsconfig.json && node dist/cli.js doctor && node dist/cli.js help",
    "verify": "tsc --noEmit -p tsconfig.json && tsc -p tsconfig.json && tsc --noEmit --strict --target ES2022 --module NodeNext --moduleResolution NodeNext examples/typecheck.ts && node --test tests/*.test.mjs && node scripts/smoke-package.mjs && node scripts/run-quickstart.mjs && node scripts/fresh-dev-setup.mjs && node dist/cli.js doctor && node dist/cli.js help",
    "prepack": "rm -rf dist && tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
